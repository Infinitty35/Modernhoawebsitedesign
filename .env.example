# SMTP credentials for the contact-form email server
# Copy this file to .env and fill in the real values before starting the server.

# The Outlook / Microsoft 365 address that SENDS the email (must match your SMTP login)
EMAIL_USER=your_outlook_email@outlook.com

# App password generated in your Microsoft account security settings
# (NOT your regular account password — see https://support.microsoft.com/en-us/account-billing/manage-app-passwords-for-two-step-verification-d6dc8c6d-4bf7-4851-ad95-6d07799387e9)
APPPASSWORD=your_app_password_here

# Email address that will RECEIVE the contact-form submissions
RECIPIENT_EMAIL=elandon@outlook.com

# Port the Express server listens on (default: 3001)
PORT=3001

# Frontend origin allowed by CORS (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Vite environment variable: URL of the email backend (used in Contact.tsx)
# Add this to your frontend .env if deploying to production
VITE_API_URL=http://localhost:3001
